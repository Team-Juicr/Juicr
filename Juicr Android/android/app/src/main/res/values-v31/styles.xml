<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowSplashScreenBackground">#131218</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_empty</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#131218</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">#131218</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>
</resources>
